<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        android:contentDescription="شعار بلايند هاب"
        android:src="@android:drawable/ic_lock_lock"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/login_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="بلايند هاب - BlindHub"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:contentDescription="عنوان التطبيق: بلايند هاب للمكفوفين"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo" />

    <Button
        android:id="@+id/btn_quick_start"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="48dp"
        android:backgroundTint="#25D366"
        android:text="تسجيل سريع (ابدأ الآن)"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:contentDescription="زر التسجيل السريع، اضغط للدخول الفوري وبدء المحادثات"
        app:layout_constraintTop_toBottomOf="@id/login_header" />

    <EditText
        android:id="@+id/et_phone_or_name"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="@android:drawable/editbox_background"
        android:hint="أو أدخل رقم هاتفك/اسمك"
        android:inputType="text"
        android:padding="12dp"
        android:textColor="#000000"
        android:contentDescription="حقل إدخال رقم الهاتف أو الاسم"
        app:layout_constraintTop_toBottomOf="@id/btn_quick_start" />

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#1DA1F2"
        android:text="دخول بحساب سابق"
        android:textColor="#FFFFFF"
        android:contentDescription="زر الدخول بحساب مسجل مسبقاً"
        app:layout_constraintTop_toBottomOf="@id/et_phone_or_name" />

</androidx.constraintlayout.widget.ConstraintLayout>
